{
  "name": "agent-office",
  "version": "0.1.0",
  "description": "A local developer tool that gives you a team of AI coding agents",
  "type": "module",
  "bin": {
    "agent-office": "./bin/agent-office.js"
  },
  "main": "src/api/server.js",
  "scripts": {
    "start": "node bin/agent-office.js start",
    "startup": "bash scripts/startup.sh",
    "startup:dev": "bash scripts/dev-start.sh",
    "dev": "node --watch bin/agent-office.js start",
    "dev:ui": "cd ui && npm run dev",
    "build:ui": "cd ui && npm run build",
    "linkedin": "node scripts/linkedin-capture.mjs",
    "doctor": "node bin/agent-office.js doctor",
    "install:hooks": "node scripts/install-hooks.js",
    "postinstall": "node -e \"try { const fs = require('fs'); const p = require.resolve('node-pty/package.json'); const dir = require('path').join(require('path').dirname(p), 'prebuilds'); for (const sub of fs.readdirSync(dir)) { const helper = require('path').join(dir, sub, 'spawn-helper'); if (fs.existsSync(helper)) fs.chmodSync(helper, 0o755); } } catch {}\"",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test 'test/db/**/*.test.js' 'test/history/**/*.test.js' 'test/memory/**/*.test.js' 'test/skills/**/*.test.js' 'test/frontdesk/**/*.test.js' 'test/context-budget/**/*.test.js' 'test/core/**/*.test.js' 'test/agents/**/*.test.js' 'test/providers/capability-registry.test.js' 'test/providers/claude-code-adapter.test.js' 'test/providers/lmstudio-bridge.test.js' 'test/providers/codex-adapter-contract.test.js' 'test/providers/gemini-cli-adapter-contract.test.js' 'test/providers/install-hooks-on-boot.test.js' 'test/providers/aider-local.test.js' 'test/telemetry/pricing.test.js' 'test/telemetry/abtop-parser.test.js' 'test/telemetry/session-aggregator.test.js' 'test/telemetry/tracker-unattended.test.js' 'test/telemetry/claude-projects-path.test.js'",
    "test:integration": "node --test 'test/integration/**/*.test.js' 'test/api/**/*.test.js' 'test/cli.test.js' 'test/providers/manifest.test.js' 'test/stats/**/*.test.js' 'test/telemetry/codex-watcher.test.js' 'test/telemetry/gemini-watcher.test.js' 'test/telemetry/jsonl-watcher.test.js' 'test/telemetry/aider-watcher.test.js' 'test/telemetry/abtop-bridge.test.js' 'test/telemetry/outcome-inference.test.js'",
    "test:watch": "node --test --watch 'test/**/*.test.js'"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@huggingface/transformers": "^4.1.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "sqlite-vec": "^0.1.9",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
